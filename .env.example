NEXT_PUBLIC_SITE_NAME=Assisted Living Help
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_ID=
SUPABASE_DB_PASSWORD=

# Resend — email confirmations
# Sign up at https://resend.com, verify your sending domain, and add an API key.
# RESEND_FROM_EMAIL must be a verified sender address or use the verified domain.
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Twilio — SMS confirmations
# Account SID and Auth Token from https://console.twilio.com
# TWILIO_FROM_NUMBER must be a purchased Twilio number in E.164 format, e.g. +12095550100
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Meta lead form ingestion (future)
META_WEBHOOK_VERIFY_TOKEN=
